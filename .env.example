# 环境配置
ENV=development
PROJECT_NAME=AI-Interview
API_V1_STR=/api/v1
API_PORT=8006

# 数据库配置
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_interview

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# HTTP 代理配置（一般不需要开启）
USE_HTTP_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=

# 邮件配置（当前未启用，保留默认即可）
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=user
MAIL_PASSWORD=password
MAIL_FROM_ADDRESS=noreply@ai-interview.com
MAIL_FROM_NAME=AI-Interview
MAIL_ENCRYPTION=none

# Brevo 邮件服务（当前未启用）
BREVO_API_KEY=dummy-api-key
BREVO_EMAIL_FROM=noreply@ai-interview.com
BREVO_EMAIL_FROM_NAME=AI-Interview

# 管理员邮箱
ADMIN_EMAIL=admin@ai-interview.com

# JWT 配置
SECRET_KEY=ai-interview-dev-secret-key-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 配置（当前未启用，使用本地存储）
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket
AWS_ENDPOINT=https://s3.amazonaws.com

# OpenAI 配置（当前未使用）
OPENAI_API_KEY=your-openai-api-key

# DeepSeek AI 配置（必填）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============= RAG 知识库 / Embedding 配置 =============
# 阿里云 DashScope API Key（必填）
# 申请地址：https://dashscope.console.aliyun.com → 开通"通用文本向量"服务
DASHSCOPE_API_KEY=

# Embedding 模型配置（不要随意改 DIM，改了需要重建索引）
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-v3
KNOWLEDGE_EMBEDDING_DIM=1024

# 文档切分参数
KNOWLEDGE_CHUNK_SIZE=500
KNOWLEDGE_CHUNK_OVERLAP=50

# 文档检索参数（用于答案评分、用户答疑）
KNOWLEDGE_TOP_K=4
KNOWLEDGE_MIN_SCORE=0.3

# 题库召回参数（用于面试出题，核心）
QUESTION_BANK_MIN_SCORE=0.7
QUESTION_BANK_RECALL_FACTOR=2
QUESTION_BANK_TOP_K=20
